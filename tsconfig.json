{
  "compilerOptions": {
    "noEmit": true,
    "strict": true,
    "module": "ESNext",
    "moduleResolution": "bundler",
    "target": "ES2022",
    "lib": ["ES2022", "ES2022.Array"],
    "types": ["node"],
    "allowImportingTsExtensions": false,
    "skipLibCheck": true
  },
  "include": ["core/*.ts"],
  "exclude": ["node_modules", "dist"]
}
