{
  "compilerOptions": {
    "noEmit": true,
    "strict": false,
    "checkJs": true,
    "allowJs": true,
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "target": "ES2022",
    "lib": ["ES2022", "ES2022.Array"],
    "types": ["node"],
    "skipLibCheck": true
  },
  "include": ["core/**/*.js"],
  "exclude": ["node_modules", "dist"]
}
