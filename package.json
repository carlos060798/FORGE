{
  "name": "forge-sdd",
  "version": "4.0.0",
  "description": "Tu equipo técnico completo en Claude Code. Di tu idea — FORGE la especifica, construye, prueba y verifica. Sin escribir código.",
  "type": "module",
  "bin": {
    "forge": "cli/index.js",
    "sdd-es": "cli/index.js"
  },
  "scripts": {
    "test": "node --test tests/*.test.js __tests__/*.test.js",
    "test:verbose": "node --test --reporter=spec tests/*.test.js __tests__/*.test.js",
    "coverage": "node --test --experimental-test-coverage tests/*.test.js __tests__/*.test.js",
    "init": "echo 'Instala con: npx forge init  (o npx sdd-es init)'",
    "doctor": "node cli/index.js doctor"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "files": [
    "cli/",
    "bin/",
    "core/",
    "commands/",
    "agents/",
    "skills/",
    "craft/",
    "design-systems/",
    "plantillas/",
    "presets/",
    "claude-hooks/",
    "configuracion-ejemplo/",
    "docs/",
    "ui/",
    ".claude-plugin/",
    ".gitignore",
    ".mcp.json",
    "instalar.sh",
    "instalar.ps1",
    "README.md",
    "QUICK-START.md",
    "CHANGELOG.md",
    "VERSIONING.md",
    "LICENSE"
  ],
  "keywords": [
    "forge",
    "claude-code",
    "spec-driven-development",
    "sdd",
    "tdd",
    "español",
    "agentes",
    "mcp",
    "plugin",
    "no-code",
    "citizen-developer"
  ],
  "license": "MIT",
  "homepage": "https://github.com/carlos060798/FORGE",
  "repository": {
    "type": "git",
    "url": "https://github.com/carlos060798/FORGE.git"
  },
  "dependencies": {
    "@sqlite.org/sqlite-wasm": "^3.53.0-build1",
    "acorn": "^8.17.0"
  }
}
