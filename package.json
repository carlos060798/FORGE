{
  "name": "sdd-es",
  "version": "2.7.0",
  "description": "Spec-Driven Development en español para Claude Code. Fábrica de software: de la idea al despliegue, agnóstica al stack. v2.7.0: routing dinámico de modelos, umbral configurable, tests nativos, guardrails ACI.",
  "type": "module",
  "bin": {
    "sdd-es": "cli/index.js"
  },
  "scripts": {
    "test": "node --test tests/*.test.js __tests__/*.test.js",
    "test:verbose": "node --test --reporter=spec tests/*.test.js __tests__/*.test.js",
    "coverage": "node --test --experimental-test-coverage tests/*.test.js __tests__/*.test.js",
    "init": "echo 'Instala con: npx sdd-es init  (o /plugin install sdd-es en Claude Code)'",
    "doctor": "node cli/index.js doctor"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "files": [
    "cli/",
    "bin/",
    "core/",
    "commands/",
    "agents/",
    "skills/",
    "craft/",
    "design-systems/",
    "plantillas/",
    "presets/",
    "claude-hooks/",
    "configuracion-ejemplo/",
    "docs/",
    ".claude-plugin/",
    ".gitignore",
    ".mcp.json",
    "instalar.sh",
    "instalar.ps1",
    "README.md",
    "QUICK-START.md",
    "CHANGELOG.md",
    "VERSIONING.md",
    "LICENSE"
  ],
  "keywords": [
    "claude-code",
    "spec-driven-development",
    "sdd",
    "español",
    "agentes",
    "mcp",
    "plugin"
  ],
  "license": "MIT",
  "homepage": "https://github.com/carlos060798/FORGE",
  "repository": {
    "type": "git",
    "url": "https://github.com/carlos060798/FORGE.git"
  }
}
